{
  "name": "fixed_triple_xgb_fusion_reproduction",
  "dataset": {
    "manifest": "data/processed/runs/daisee_4class_final_dataset/feature_manifest.csv",
    "label_space": "4-class DAiSEE engagement labels from the processed final dataset",
    "feature_mode": "tsfresh"
  },
  "base_models": {
    "final_xgb": {
      "artifact_model": "checkpoints/runs/product_4class_fixed_triple_xgb/final_xgb/model.json",
      "artifact_preprocessor": "checkpoints/runs/product_4class_fixed_triple_xgb/final_xgb/preprocessor.npz"
    },
    "boost_xgb": {
      "artifact_model": "checkpoints/runs/product_4class_fixed_triple_xgb/boost_xgb/model.json",
      "artifact_preprocessor": "checkpoints/runs/product_4class_fixed_triple_xgb/boost_xgb/preprocessor.npz"
    },
    "targeted_xgb": {
      "artifact_model": "checkpoints/runs/product_4class_fixed_triple_xgb/targeted_xgb/model.json",
      "artifact_preprocessor": "checkpoints/runs/product_4class_fixed_triple_xgb/targeted_xgb/preprocessor.npz"
    }
  },
  "fusion_parameters": {
    "method": "weighted probability average followed by class-bias and temperature calibration",
    "weights": {
      "final_xgb": 0.84,
      "boost_xgb": 0.14,
      "targeted_xgb": 0.02
    },
    "bias_power": 0.42,
    "temperature": 1.15
  },
  "reproduction_command": "bash scripts/reproduce_product_4class.sh",
  "summary_output": "checkpoints/runs/product_4class_fixed_triple_xgb/summary.json"
}
